rules_version = '2';
// 🛡️ OdyShare Fortress Rules - Schema-enforced access boundary
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. ID validation helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. User shape validation
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'password', 'name', 'email'])
        && data.username is string && data.username.size() <= 100
        && data.password is string && data.password.size() <= 200
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150;
    }

    // 4. Trip shape validation
    function isValidTrip(data) {
      return data.keys().hasAll(['name', 'destination', 'startDate', 'endDate', 'totalBudget'])
        && data.name is string && data.name.size() <= 200
        && data.destination is string && data.destination.size() <= 200
        && data.startDate is string && data.startDate.size() <= 20
        && data.endDate is string && data.endDate.size() <= 20
        && data.totalBudget is number;
    }

    // 5. Invitation shape validation
    function isValidInvitation(data) {
      return data.keys().hasAll(['tripId', 'tripName', 'inviterId', 'inviteeId', 'status'])
        && data.tripId is string && data.tripId.size() <= 100
        && data.tripName is string && data.tripName.size() <= 200
        && data.inviterId is string && data.inviterId.size() <= 100
        && data.inviteeId is string && data.inviteeId.size() <= 100
        && data.status is string && data.status.size() <= 50;
    }

    // Users resource rules
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidId(userId) && isValidUser(request.resource.data);
      allow delete: if isValidId(userId);
    }

    // Trips resource rules
    match /trips/{tripId} {
      allow read: if true;
      allow create, update: if isValidId(tripId) && isValidTrip(request.resource.data);
      allow delete: if isValidId(tripId);
    }

    // Invitations resource rules
    match /invitations/{invitationId} {
      allow read: if true;
      allow create, update: if isValidId(invitationId) && isValidInvitation(request.resource.data);
      allow delete: if isValidId(invitationId);
    }

    // Config resource rules
    match /config/{configId} {
      allow read: if true;
      allow write: if isValidId(configId);
    }
  }
}
